{
  "name": "nh-dao-registry-poc",
  "version": "0.6.0",
  "description": "Reference implementation of the NH DAO Registry POC (v0.6): two-DID model with did:web identifiers, mandatory IPFS pinning, Polygon Amoy chain anchor.",
  "type": "module",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node dist/src/server.js",
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "hardhat test test/DAORegistryAnchor.test.cjs && node --import tsx --test test/e2e.test.js",
    "test:contract": "hardhat test test/DAORegistryAnchor.test.cjs",
    "test:e2e": "node --import tsx --test test/e2e.test.js",
    "test:integration": "hardhat compile && node --import tsx --test test/integration.test.js",
    "compile": "hardhat compile",
    "deploy:amoy": "hardhat run scripts/deploy.cjs --network amoy",
    "deploy:local": "hardhat run scripts/deploy.cjs --network localhost",
    "node:local": "hardhat node",
    "verify": "tsx scripts/verify-record.ts",
    "balances": "tsx scripts/balances.ts",
    "backup": "tsx scripts/backup.ts"
  },
  "dependencies": {
    "@noble/curves": "^1.4.0",
    "@noble/hashes": "^1.4.0",
    "arweave": "^1.15.7",
    "dotenv": "^16.4.5",
    "ethers": "^6.13.0",
    "express": "^4.21.0",
    "multiformats": "^13.1.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "hardhat": "^2.22.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
